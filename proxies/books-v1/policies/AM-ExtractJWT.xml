<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<AssignMessage continueOnError="false" enabled="true" name="AM-ExtractJWT">
  <DisplayName>AM-ExtractJWT</DisplayName>
  <AssignVariable>
    <Name>jwt.raw.token</Name>
    <Template>{substring(request.header.authorization,7)}</Template>
  </AssignVariable>
  <IgnoreUnresolvedVariables>true</IgnoreUnresolvedVariables>
</AssignMessage>
